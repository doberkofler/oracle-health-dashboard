{
  "name": "oracle-health-dashboard",
  "version": "0.0.1",
  "description": "NodeJS based dashboard to monitor Oracle instances.",
  "exports": "./build/src/index.js",
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "compression": "1.7.4",
    "date-fns": "2.28.0",
    "debug": "4.3.4",
    "express": "4.17.3",
    "oracledb": "5.3.0",
    "ping": "0.4.1",
    "react": "17.0.2",
    "react-dom": "17.0.2",
    "threads": "1.7.0",
    "tslib": "2.3.1",
    "yargs": "17.4.0"
  },
  "devDependencies": {
    "@types/compression": "^1.7.2",
    "@types/debug": "^4.1.7",
    "@types/express": "4.17.13",
    "@types/jest": "27.4.1",
    "@types/node": "17.0.23",
    "@types/oracledb": "5.2.3",
    "@types/ping": "0.4.1",
    "@types/react": "17.0.43",
    "@types/react-dom": "17.0.14",
    "@types/supertest": "2.0.12",
    "@types/yargs": "17.0.10",
    "@typescript-eslint/eslint-plugin": "5.16.0",
    "@typescript-eslint/parser": "5.16.0",
    "esbuild": "0.14.28",
    "eslint": "8.12.0",
    "eslint-plugin-jest": "26.1.3",
    "eslint-plugin-react": "7.29.4",
    "eslint-plugin-react-hooks": "4.3.0",
    "fs-extra": "10.0.1",
    "jest": "27.5.1",
    "nodemon": "2.0.15",
    "rimraf": "3.0.2",
    "supertest": "6.2.2",
    "ts-jest": "27.1.4",
    "tsutils": "3.21.0",
    "typescript": "4.6.3"
  },
  "scripts": {
    "start": "nodemon --watch out --watch config out/server/index.js --config=./config/config.json",
    "clean": "rimraf coverage build tmp && jest --clearCache",
    "build": "npm run clean && node build.js",
    "build:watch": "nodemon --ext ts,tsx,css --watch src build.js",
    "lint": "eslint . --ext .ts,.tsx && tsc --noEmit",
    "test": "jest --coverage=false",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch --coverage=false"
  },
  "author": "Dieter Oberkofler <doberkofler@users.noreply.github.com",
  "license": "Apache-2.0",
  "volta": {
    "node": "16.13.0"
  }
}
