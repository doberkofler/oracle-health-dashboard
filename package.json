{
  "name": "oracle-health-dashboard",
  "version": "0.0.1",
  "description": "NodeJS based dashboard to monitor Oracle instances.",
  "type": "module",
  "exports": "./build/src/index.js",
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "compression": "1.7.4",
    "date-fns": "2.28.0",
    "debug": "4.3.3",
    "express": "4.17.2",
    "oracledb": "5.3.0",
    "ping": "0.4.1",
    "react": "17.0.2",
    "react-dom": "17.0.2",
    "threads": "1.7.0",
    "tslib": "2.3.1",
    "yargs": "17.3.1"
  },
  "devDependencies": {
    "@types/compression": "^1.7.2",
    "@types/debug": "^4.1.7",
    "@types/express": "4.17.13",
    "@types/jest": "27.4.0",
    "@types/node": "17.0.13",
    "@types/oracledb": "5.2.2",
    "@types/ping": "0.4.1",
    "@types/react": "17.0.38",
    "@types/react-dom": "17.0.11",
    "@types/supertest": "2.0.11",
    "@types/yargs": "17.0.8",
    "@typescript-eslint/eslint-plugin": "5.10.1",
    "@typescript-eslint/parser": "5.10.1",
    "bootstrap-icons": "1.7.2",
    "eslint": "8.8.0",
    "eslint-plugin-jest": "26.0.0",
    "jest": "27.4.7",
    "nodemon": "2.0.15",
    "rimraf": "3.0.2",
    "supertest": "6.2.2",
    "ts-jest": "27.1.3",
    "tsutils": "3.21.0",
    "typescript": "4.5.5"
  },
  "scripts": {
    "start": "node build/src/index.js",
    "start:watch": "nodemon --watch build/src --watch ./test-configs build/src/index.js --config=./config/config.json",
    "clean": "rimraf coverage build tmp && jest --clearCache",
    "build": "npm run clean && tsc -p tsconfig.release.json",
    "build:watch": "tsc -w -p tsconfig.release.json",
    "lint": "eslint . --ext .ts,.tsx && tsc --noEmit",
    "test": "jest --coverage=false",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch --coverage=false"
  },
  "author": "Dieter Oberkofler <doberkofler@users.noreply.github.com",
  "license": "Apache-2.0",
  "volta": {
    "node": "16.13.0"
  }
}
